# ═══════════════════════════════════════════════════════
#  Python
# ═══════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ═══════════════════════════════════════════════════════
#  Virtual environments
# ═══════════════════════════════════════════════════════
venv/
.venv/
env/
ENV/
.python-version

# ═══════════════════════════════════════════════════════
#  Distribution / packaging
# ═══════════════════════════════════════════════════════
dist/
build/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ═══════════════════════════════════════════════════════
#  Secrets & environment config  ← never commit these
# ═══════════════════════════════════════════════════════
.env
.env.*
!.env.example

# ═══════════════════════════════════════════════════════
#  Logs  (generated at runtime)
# ═══════════════════════════════════════════════════════
logs/
*.log

# ═══════════════════════════════════════════════════════
#  Runtime-generated data  (rebuilt automatically)
# ═══════════════════════════════════════════════════════

# FAISS index files
data_flat/

# Temporary query image uploads
static/upload/

# BG-removed preprocessed PNG cache
static/preprocessed/

# ═══════════════════════════════════════════════════════
#  ML model cache  (auto-downloaded by transformers/rembg)
# ═══════════════════════════════════════════════════════
.cache/
huggingface_cache/
transformers_cache/

# ═══════════════════════════════════════════════════════
#  Docker
# ═══════════════════════════════════════════════════════
.dockerignore

# ═══════════════════════════════════════════════════════
#  Testing
# ═══════════════════════════════════════════════════════
.pytest_cache/
.coverage
htmlcov/
*.xml

# ═══════════════════════════════════════════════════════
#  IDE / Editor
# ═══════════════════════════════════════════════════════
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ═══════════════════════════════════════════════════════
#  OS artefacts
# ═══════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
